{
  "uid": "msa-dev",
  "title": "MSA Dev",
  "description": "Microservice Architecture development dashboard — traces, metrics, and logs per service",
  "tags": ["msa", "dev", "otel"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "15s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m", "15m", "30m"]
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "uid": "prometheus", "type": "prometheus" },
        "query": "label_values(traces_span_metrics_calls_total, service_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 30,
      "type": "row",
      "title": "Per Service — Traces / Metrics / Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Traces Received",
      "description": "Y-axis: span calls per second (rate over 5m window). Each line = one service. Source: spanmetrics connector → Prometheus. Higher values mean more trace activity.",
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Metrics Received",
      "description": "Y-axis: span duration metric events per second (rate over 5m window). Each line = one service. Source: spanmetrics connector → Prometheus. Tracks how many span duration data points are recorded.",
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_duration_milliseconds_count{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Logs Received",
      "description": "Y-axis: log lines per second (rate over 5m window). Each line = one service. Source: Loki. Comparable to the Traces and Metrics charts which also show per-second rates.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"}[5m]) / 300)",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 34,
      "type": "table",
      "title": "Trace Spans (click row to expand)",
      "description": "Recent trace spans from Tempo. Click a Trace ID to open the full trace waterfall in Explore. Sorted by start time (newest first).",
      "datasource": { "uid": "tempo", "type": "tempo" },
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 9 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Start time", "desc": true }],
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              { "id": "links", "value": [{ "title": "View Trace", "url": "/explore?orgId=1&left=%7B%22datasource%22:%22tempo%22,%22queries%22:%5B%7B%22queryType%22:%22traceql%22,%22query%22:%22${__value.raw}%22%7D%5D%7D", "targetBlank": true }] }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "tempo", "type": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name =~ \"$service\"}",
          "tableType": "traces",
          "limit": 20
        }
      ]
    },
    {
      "id": 35,
      "type": "table",
      "title": "Span Metrics Detail",
      "description": "Instant snapshot of all span metrics. Columns: Service, Span Name, Kind, Status, Total Calls. Click column headers to sort. Source: traces_span_metrics_calls_total in Prometheus.",
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 9 },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }],
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "traces_span_metrics_calls_total{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} | {{span_name}} | {{status_code}}",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "deployment_environment": true },
            "renameByName": { "service_name": "Service", "span_name": "Span Name", "span_kind": "Kind", "status_code": "Status", "http_method": "Method", "http_status_code": "HTTP Code", "Value": "Total Calls" }
          }
        }
      ]
    },
    {
      "id": 36,
      "type": "logs",
      "title": "Log Entries (click row to expand)",
      "description": "Recent log entries from Loki. Click any row to expand and inspect all labels, parsed fields, and structured metadata. Most recent entries shown first.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 9 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "{service_name=~\"$service\"}",
          "queryType": "range",
          "maxLines": 100
        }
      ]
    },
    {
      "id": 1,
      "type": "row",
      "title": "Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Span Rate by Service",
      "description": "Y-axis: span calls per second (rate over 5m window). Each line = one service. Source: traces_span_metrics_calls_total in Prometheus. Use this to compare request volumes across services.",
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Span Duration p95 by Service",
      "description": "Y-axis: 95th percentile span duration in milliseconds. Each line = one service. Source: traces_span_metrics_duration_milliseconds_bucket in Prometheus. Spikes indicate latency degradation.",
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(traces_span_metrics_duration_milliseconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error Rate by Service",
      "description": "Y-axis: error span calls per second (status_code=STATUS_CODE_ERROR). Each line = one service. Source: traces_span_metrics_calls_total filtered by error status. Non-zero values indicate failures.",
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\", status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Service Activity",
      "description": "Shows whether each service is actively reporting spans. Green = spans received recently. Red/INACTIVE = no span data in the selected time range. Source: rate of traces_span_metrics_calls_total.",
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "INACTIVE", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "prometheus", "type": "prometheus" },
          "expr": "sum by (service_name) (rate(traces_span_metrics_calls_total{service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "traces",
      "title": "Recent Traces by Service",
      "description": "Searchable list of recent traces from Tempo, filtered by service name. Click a trace to view the full span waterfall. Uses TraceQL: {resource.service.name =~ \"$service\"}.",
      "datasource": { "uid": "tempo", "type": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 37 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "tempo", "type": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name =~ \"$service\"}",
          "limit": 20
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "logs",
      "title": "Service Logs",
      "description": "Full log stream from Loki for selected services. Click any entry to expand and view all labels and fields. Supports text search in the query bar.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 50 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "{service_name=~\"$service\"}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Log Volume by Service",
      "description": "Y-axis: total log lines per 5-minute window, stacked by service. Source: count_over_time in Loki. Helps identify which services produce the most logs and spot sudden volume changes.",
      "datasource": { "uid": "loki", "type": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 62 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "uid": "loki", "type": "loki" },
          "expr": "sum by (service_name) (count_over_time({service_name=~\"$service\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    }
  ]
}
